<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Allow the application to execute code pages, which is required for the V8 JavaScript engine (used by Electron) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow the application to create executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    
    <!-- Allow loading of third-party libraries without signatures (useful for some native node modules like sharp if they aren't signed properly) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- Allow the application to execute unsigned executable memory -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
  </dict>
</plist>
